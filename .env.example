# --- Postgres ---
POSTGRES_PASSWORD=change-me

# --- Service ---
WORKERS=2
# Embedding model (numpy static, no torch). retrieval-tuned, ~290x faster than MiniLM.
MODEL_NAME=minishlab/potion-retrieval-32M
# Limit the CVE mirror for testing, e.g. CVE_ECOSYSTEMS=PyPI,npm. Empty = full set
# (all languages + OS distros; ~13 min initial sync, ~4 GB Postgres).
CVE_ECOSYSTEMS=

# --- Exposing the MCP (DNS-rebinding guard) ---
# Comma-separated hostname(s) the /mcp transport will accept. localhost works for
# on-box use; set this to your public hostname when exposing (else clients get 421).
ADVISOR_ALLOWED_HOSTS=localhost,127.0.0.1
# Only if a browser app calls /mcp — comma-separated, exact-match origins.
ADVISOR_ALLOWED_ORIGINS=

# Note: the advisor port is bound to 127.0.0.1 — put your own reverse proxy / TLS in
# front to expose it (see docs/self-hosting.md). DATABASE_URL is wired automatically
# in docker-compose.yml from POSTGRES_PASSWORD; override only when running outside compose.
